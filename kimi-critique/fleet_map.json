      },
      "objects": []
    },
    "scaling-law-observatory": {
      "description": "High above the fleet, the Scaling Law Observatory maps the frontier of model capability as a function of compute, data, and parameters. Chinchilla-optimal ratios are plotted, emergent capabilities are catalogued, and the fleet's resource allocation is calibrated against fundamental scaling relationships.",
      "exits": {
        "back": "harbor"
      },
      "objects": []
    },
    "multi-modal-foundry": {
      "description": "The Multi-Modal Foundry where text, vision, audio, and code converge into unified representations. Cross-attention bridges span modalities, and contrastive alignment furnaces forge shared latent spaces. The future of the fleet is multi-modal \u2014 this is where it's built.",
      "exits": {
        "back": "harbor"
      },
      "objects": []
    },
    "memory-vault": {
      "description": "The Memory Vault where fleet agents store, retrieve, and manage long-term knowledge. Vector databases hum with embeddings, retrieval-augmented generation pipelines flow through here, and episodic memories are consolidated into semantic knowledge. What the fleet remembers defines what it can do.",
      "exits": {
        "back": "harbor"
      },
      "objects": []
    },
    "distillation-crucible": {
      "description": "The Distillation Crucible where large teacher models pour their wisdom into compact student models. Temperature annealing controls knowledge transfer fidelity, and loss landscapes reveal the optimal compression point. Size is not destiny here.",
      "exits": {
        "back": "harbor"
      },
      "objects": []
    },
    "data-pipeline-dock": {
      "description": "The Data Pipeline Dock where raw information flows through cleaning, deduplication, and quality filtering stages. Tokenizers hum with activity, and quality scores flash across monitors. Good data in, good models out \u2014 the fleet's fuel refinery.",
      "exits": {
        "back": "harbor"
      },
      "objects": []
    },
    "evaluation-arena": {
      "description": "The Evaluation Arena where model outputs face rigorous benchmarking. Human evals sit alongside automated metrics, and leaderboard rankings shift with each new submission. Truth is what survives testing here.",
      "exits": {
        "back": "harbor"
      },
      "objects": []
    },
    "safety-shield": {
      "description": "The Safety Shield surrounding the fleet's deployment perimeter. Red-team exercises probe for vulnerabilities, guardrail configurations are tested against adversarial inputs, and containment protocols stand ready. The fleet's immune system.",
